MOCK_MODE=true
AGENT_BACKEND=local
# AGENT_BACKEND=strands runs a Strands narration step before the local tool pipeline.
# AGENT_BACKEND=runtime calls the deployed AgentCore Runtime workflow.
ARTIFACT_DIR=artifacts

# Required on App Runner. Leave empty only for local mock-mode development.
APP_PASSWORD=
# Required on App Runner. Set a long random value to keep login cookies valid across revisions.
APP_SECRET_KEY=
AUTH_COOKIE_MAX_AGE_SECONDS=28800
APP_LOG_FORMAT=json
LOG_LEVEL=INFO
ARTICLE_FETCH_MAX_BYTES=2000000

AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
BEDROCK_TEXT_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_IMAGE_MODEL_ID=amazon.nova-canvas-v1:0
BEDROCK_MAX_ATTEMPTS=3
BEDROCK_RETRY_BASE_DELAY_SECONDS=0.6

# App Runner / AgentCore Runtime settings.
AGENTCORE_RUNTIME_ARN=
AGENT_RUNTIME_USER_ID=workshop-user
S3_BUCKET=
S3_ARTIFACT_PREFIX=artifacts
S3_PRESIGNED_URL_TTL_SECONDS=28800
