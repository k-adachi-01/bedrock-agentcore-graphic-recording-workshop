MOCK_MODE=true
AGENT_BACKEND=local
# AGENT_BACKEND=adk runs a Google ADK LlmAgent/Runner narration step before the local tool pipeline.
# AGENT_BACKEND=runtime is reserved for Agent Runtime integration.
ARTIFACT_DIR=artifacts
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Required on Cloud Run. Leave empty only for local mock-mode development.
APP_PASSWORD=
# Required on Cloud Run. Set a long random value to keep login cookies valid across revisions.
APP_SECRET_KEY=
AUTH_COOKIE_MAX_AGE_SECONDS=28800
APP_LOG_FORMAT=json
LOG_LEVEL=INFO
ARTICLE_FETCH_MAX_BYTES=2000000
GEMINI_MAX_ATTEMPTS=3
GEMINI_RETRY_BASE_DELAY_SECONDS=0.6

# Local fallback for Gemini Developer API. Prefer Vertex AI for the workshop demo.
GEMINI_API_KEY=

# Preferred for Cloud Run / Gemini Enterprise Agent Platform with ADC.
GOOGLE_GENAI_USE_VERTEXAI=true

# Cloud Run / Agent Runtime settings.
AGENT_RUNTIME_URL=
AGENT_RUNTIME_RESOURCE_NAME=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GCS_BUCKET=
GCS_ARTIFACT_PREFIX=artifacts
